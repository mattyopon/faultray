# FaultRay environment template — copy to .env and fill in real values.
# DO NOT commit .env / .env.* (gitignored by .gitignore and refused by pre-commit).
# See #136 for rotation and storage guidance.

# ---------------------------------------------------------------------------
# Stripe billing (#79, #112)
# Comma-separated Stripe Price IDs that map to each plan tier in
# planTierFromPriceId. STRIPE_PRO_PRICE_ID / STRIPE_BUSINESS_PRICE_ID are
# kept for legacy single-value callers; prefer the *_IDS plurals when
# you need multiple prices per tier.
# ---------------------------------------------------------------------------
STRIPE_PRO_PRICE_ID=
STRIPE_BUSINESS_PRICE_ID=

# ---------------------------------------------------------------------------
# OAuth SSO (#136, #137)
# Generate per-provider OAuth apps at:
#   GitHub:  https://github.com/settings/developers
#   Google:  https://console.cloud.google.com/apis/credentials
# Rotate immediately if .env was ever shared or copied into an image.
# ---------------------------------------------------------------------------
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# JWT signing key (#137)
# Required for create_jwt / decode_jwt. Must be >= 32 characters of
# entropy and must not be a known sentinel (faultray-dev-secret-change-me,
# change-me, REPLACE_ME, secret, ...). Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# ---------------------------------------------------------------------------
FAULTRAY_JWT_SECRET=
# Legacy alias still honored by oauth.py; FAULTRAY_JWT_SECRET wins when both are set.
JWT_SECRET_KEY=

# ---------------------------------------------------------------------------
# Setup gate (#140)
# Required for the first POST /setup on any non-loopback deployment.
# Unset (or leave blank) after the first admin is created so /setup
# stops accepting requests.
# ---------------------------------------------------------------------------
FAULTRAY_BOOTSTRAP_TOKEN=

# ---------------------------------------------------------------------------
# Plugin trust gate (#150)
# Colon-separated list of absolute paths that --plugins-dir / --trust-plugins-dir
# is allowed to load from. Must explicitly opt in on both the CLI flag and
# this env to load anything.
# ---------------------------------------------------------------------------
FAULTRAY_PLUGIN_TRUSTED_DIRS=

# ---------------------------------------------------------------------------
# Cloudflare DNS automation (optional)
# ---------------------------------------------------------------------------
CF_API_TOKEN=
CF_ZONE_ID=

# ---------------------------------------------------------------------------
# Dev.to publishing helper (#148)
# Generate at https://dev.to/settings/extensions. The publish-devto.sh
# script reads DEVTO_API_KEY from the environment, never from disk.
# ---------------------------------------------------------------------------
DEVTO_API_KEY=
